# Apollo-Agent Environment Variables
# Copy to .env for local development
# ⚠️  NEVER commit actual keys to version control

# ── PostgreSQL ──────────────────────────────────────────────────────
POSTGRES_PASSWORD=apollo_dev_secret
DATABASE_URL=postgresql://apollo:apollo_dev_secret@postgres:5432/apollo

# ── Frontend ────────────────────────────────────────────────────────
# Update these after your backend is deployed on Railway
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ── CORS ────────────────────────────────────────────────────────────
# Set this to the Railway frontend URL in production (comma-separated).
ALLOWED_ORIGINS=http://localhost:3000

# ── Keys are entered in the UI — not here ───────────────────────────
# KALSHI_KEY_ID      → entered on /onboarding
# KALSHI_PRIVATE_KEY → uploaded via .key file on /onboarding
# BALLDONTLIE_KEY    → entered on /onboarding
# PERPLEXITY_KEY     → entered on /onboarding (optional)
